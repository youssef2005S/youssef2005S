<script>
/* ── MAIN BG THREE.JS ── */
(function(){
  const canvas = document.getElementById('three-bg');
  const W = window.innerWidth, H = window.innerHeight;
  const renderer = new THREE.WebGLRenderer({canvas, antialias:true, alpha:true});
  renderer.setPixelRatio(Math.min(devicePixelRatio,2));
  renderer.setSize(W,H);
  renderer.setClearColor(0,0);

  const scene = new THREE.Scene();
  const cam = new THREE.PerspectiveCamera(60, W/H, 0.1, 1000);
  cam.position.z = 28;

  const geoFns = [
    ()=>new THREE.IcosahedronGeometry(2,0),
    ()=>new THREE.OctahedronGeometry(1.8,0),
    ()=>new THREE.TetrahedronGeometry(2.2,0),
    ()=>new THREE.BoxGeometry(2.4,2.4,2.4),
    ()=>new THREE.IcosahedronGeometry(1.5,1),
    ()=>new THREE.OctahedronGeometry(2.4,0),
    ()=>new THREE.TetrahedronGeometry(1.6,0),
    ()=>new THREE.BoxGeometry(1.9,1.9,1.9),
    ()=>new THREE.IcosahedronGeometry(1.2,0),
  ];
  const palette = [0x00d4ff, 0x6affb0, 0xbf6aff];
  const objs = [];

  geoFns.forEach((fn,i)=>{
    const mat = new THREE.MeshBasicMaterial({
      color: palette[i%palette.length], wireframe:true,
      transparent:true, opacity: 0.08 + Math.random()*0.1
    });
    const mesh = new THREE.Mesh(fn(), mat);
    mesh.position.set(
      (Math.random()-.5)*54,
      (Math.random()-.5)*32,
      (Math.random()-.5)*18-4
    );
    mesh.rotation.set(Math.random()*Math.PI, Math.random()*Math.PI, 0);
    scene.add(mesh);
    objs.push({mesh, rx:(Math.random()-.5)*0.004, ry:(Math.random()-.5)*0.006,
      baseY:mesh.position.y, t:Math.random()*100});
  });

  // Particle field
  const N = 350, pos = new Float32Array(N*3);
  for(let i=0;i<N;i++){
    pos[i*3]   = (Math.random()-.5)*90;
    pos[i*3+1] = (Math.random()-.5)*60;
    pos[i*3+2] = (Math.random()-.5)*40-8;
  }
  const pGeo = new THREE.BufferGeometry();
  pGeo.setAttribute('position', new THREE.BufferAttribute(pos,3));
  scene.add(new THREE.Points(pGeo, new THREE.PointsMaterial({color:0x00d4ff,size:0.09,transparent:true,opacity:0.35})));

  let mx=0, my=0;
  document.addEventListener('mousemove', e=>{
    mx = (e.clientX/window.innerWidth-.5)*2;
    my = (e.clientY/window.innerHeight-.5)*2;
  });

  window.addEventListener('resize',()=>{
    cam.aspect = window.innerWidth/window.innerHeight;
    cam.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  (function tick(){
    requestAnimationFrame(tick);
    objs.forEach(o=>{
      o.t+=0.008;
      o.mesh.rotation.x+=o.rx; o.mesh.rotation.y+=o.ry;
      o.mesh.position.y = o.baseY+Math.sin(o.t)*1.4;
    });
    cam.position.x += (mx*2.5 - cam.position.x)*0.04;
    cam.position.y += (-my*2 - cam.position.y)*0.04;
    renderer.render(scene,cam);
  })();
})();

/* ── PER-CARD MINI SCENES ── */
function cardScene(id, geoType, color){
  const canvas = document.getElementById(id);
  if(!canvas) return;
  const parent = canvas.parentElement;
  const w = parent.clientWidth||340, h=200;
  const renderer = new THREE.WebGLRenderer({canvas, antialias:true, alpha:true});
  renderer.setPixelRatio(Math.min(devicePixelRatio,2));
  renderer.setSize(w,h);
  renderer.setClearColor(0,0);

  const scene = new THREE.Scene();
  const cam = new THREE.PerspectiveCamera(45, w/h, 0.1, 100);
  cam.position.z = 5.5;

  const geo = geoType===0 ? new THREE.IcosahedronGeometry(1.5,0)
            : geoType===1 ? new THREE.OctahedronGeometry(1.4,0)
            : new THREE.TetrahedronGeometry(1.7,0);

  scene.add(new THREE.Mesh(geo, new THREE.MeshPhongMaterial({color, transparent:true, opacity:0.07, shininess:60})));
  scene.add(new THREE.Mesh(geo, new THREE.MeshBasicMaterial({color, wireframe:true, transparent:true, opacity:0.55})));

  scene.add(new THREE.AmbientLight(0xffffff,.5));
  const pt = new THREE.PointLight(color, 2, 18);
  pt.position.set(3,3,4); scene.add(pt);

  let hov=false;
  const card = canvas.closest('.proj-card');
  if(card){
    card.addEventListener('mouseenter',()=>hov=true);
    card.addEventListener('mouseleave',()=>hov=false);
  }

  let t=0;
  (function tick(){
    requestAnimationFrame(tick);
    t += hov ? 0.022 : 0.006;
    scene.children[0].rotation.set(t*.7, t, 0);
    scene.children[1].rotation.set(t*.7, t, 0);
    renderer.render(scene,cam);
  })();
}

cardScene('pc1', 0, 0x00d4ff);
cardScene('pc2', 1, 0x6affb0);
cardScene('pc3', 2, 0xbf6aff);

/* ── CURSOR ── */
const cur = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
document.addEventListener('mousemove', e=>{
  cur.style.left=e.clientX+'px'; cur.style.top=e.clientY+'px';
  setTimeout(()=>{ ring.style.left=e.clientX+'px'; ring.style.top=e.clientY+'px'; },55);
});
document.querySelectorAll('a,button,input,textarea,.tilt-card,.chip').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('hovering'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('hovering'));
});

/* ── TILT ── */
document.querySelectorAll('.tilt-card').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const x=(e.clientX-r.left)/r.width-.5;
    const y=(e.clientY-r.top)/r.height-.5;
    card.style.transform=`perspective(900px) rotateY(${x*14}deg) rotateX(${-y*10}deg) translateZ(10px)`;
    const sh=card.querySelector('.card-shine');
    if(sh) sh.style.background=`radial-gradient(circle at ${(x+.5)*100}% ${(y+.5)*100}%, rgba(255,255,255,0.07) 0%, transparent 65%)`;
  });
  card.addEventListener('mouseleave',()=>{
    card.style.transform='perspective(900px) rotateY(0) rotateX(0) translateZ(0)';
  });
});

/* ── SCROLL REVEAL ── */
const io = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target); }});
},{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>

